{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git add:*)|Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/commit-validator/commit-validator.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lsp-nudge/lsp-nudge.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/format-dispatcher/format-dispatcher.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
